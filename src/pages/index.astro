---
import '../styles/tailwind.css';

const floatingSocialIcons = [
  { kind: 'note', label: 'note', left: '8%', size: '2.8rem', duration: '16s', delay: '-11s', drift: '14vw', spin: '180deg' },
  { kind: 'x', label: 'X', left: '15%', size: '2.2rem', duration: '17s', delay: '-4s', drift: '-10vw', spin: '-160deg' },
  { kind: 'instagram', label: 'Instagram', left: '28%', size: '2.4rem', duration: '15.5s', delay: '-9s', drift: '18vw', spin: '220deg' },
  { kind: 'github', label: 'GitHub', left: '44%', size: '2.3rem', duration: '18s', delay: '-13s', drift: '-12vw', spin: '-200deg' },
  { kind: 'zenn', label: 'Zenn', left: '60%', size: '2.5rem', duration: '17.5s', delay: '-6s', drift: '9vw', spin: '140deg' },
  { kind: 'qiita', label: 'Qiita', left: '73%', size: '2.45rem', duration: '16.5s', delay: '-8s', drift: '-16vw', spin: '-210deg' },
  { kind: 'note', label: 'note', left: '86%', size: '2.1rem', duration: '15s', delay: '-2s', drift: '11vw', spin: '190deg' },
  { kind: 'instagram', label: 'Instagram', left: '92%', size: '1.9rem', duration: '18.5s', delay: '-15s', drift: '-8vw', spin: '-130deg' },
];

const linkGroups = [
  {
    title: 'Social',
    description: '日々の更新や近況はこちら',
    links: [
      {
        href: 'https://twitter.com/gumigumih',
        label: 'X (Twitter)',
        description: '日々のつぶやき',
        icon: 'x',
      },
      {
        href: 'https://www.instagram.com/gumigumih',
        label: 'Instagram',
        description: '日常の写真と記録',
        icon: 'instagram',
      },
    ],
  },
  {
    title: 'Writing',
    description: '記事や学びの記録',
    links: [
      {
        href: 'https://note.com/gumigumih',
        label: 'note',
        description: '最新の文章や考えごと',
        icon: 'note',
      },
      {
        href: 'https://zenn.dev/gumigumih',
        label: 'Zenn',
        description: '技術系の記事',
        icon: 'zenn',
      },
      {
        href: 'https://qiita.com/gumigumih',
        label: 'Qiita',
        description: '実装メモと小ネタ',
        icon: 'qiita',
      },
    ],
  },
  {
    title: 'Building',
    description: 'つくったものや実験の置き場',
    links: [
      {
        href: 'https://github.com/gumigumih',
        label: 'GitHub',
        description: 'コードや制作物',
        icon: 'github',
      },
    ],
  },
];
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ぐみ | プロフィール</title>
    <!-- Google tag (gtag.js) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-VZB3MLS9Q1"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);} 
      gtag('js', new Date());

      gtag('config', 'G-VZB3MLS9Q1');
    </script>
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;700&family=Zen+Maru+Gothic:wght@300;400;500;700&family=Noto+Serif+JP:wght@400;500;700&family=Zen+Old+Mincho:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="relative min-h-screen text-gray-800 font-['Raleway']" id="app">
    <div class="fixed inset-0 bg-gradient-to-br from-rose-50 via-white to-amber-100"></div>
    <div
      class="fixed inset-0 opacity-60 bg-[radial-gradient(circle_at_20%_20%,rgba(255,164,189,0.35),transparent_30%),radial-gradient(circle_at_80%_0%,rgba(255,214,165,0.25),transparent_30%),radial-gradient(circle_at_50%_80%,rgba(255,182,193,0.22),transparent_32%)]"
    ></div>
    <div class="fixed inset-0 bg-white/20 backdrop-blur-2xl"></div>
    <div class="fixed -left-24 -top-24 w-72 h-72 bg-gradient-to-br from-pink-400/30 to-amber-300/30 rounded-full blur-3xl"></div>
    <div class="fixed -right-16 top-10 w-64 h-64 bg-gradient-to-br from-amber-300/30 to-pink-400/30 rounded-full blur-3xl"></div>
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 overflow-hidden z-0">
      {floatingSocialIcons.map((icon) => (
        <div
          class={`floating-social-icon floating-social-icon--${icon.kind}`}
          style={`left:${icon.left}; width:${icon.size}; height:${icon.size}; animation-duration:${icon.duration}; animation-delay:${icon.delay}; --drift:${icon.drift}; --spin:${icon.spin};`}
        >
          {icon.kind === 'note' && (
            <img src="/assets/images/note-icon.svg" alt="" class="h-full w-full" />
          )}
          {icon.kind === 'x' && (
            <i class="fa-brands fa-x-twitter text-[1.9rem] text-gray-800"></i>
          )}
          {icon.kind === 'instagram' && (
            <i class="fa-brands fa-instagram text-[1.95rem] text-gray-800"></i>
          )}
          {icon.kind === 'github' && (
            <i class="fa-brands fa-github text-[1.95rem] text-gray-800"></i>
          )}
          {icon.kind === 'zenn' && (
            <img src="/assets/images/zenn-logo.svg" alt="" class="h-full w-full" />
          )}
          {icon.kind === 'qiita' && (
            <img src="/assets/images/qiita-icon.png" alt="" class="h-full w-full rounded-md" />
          )}
        </div>
      ))}
    </div>
    <div
      class="relative z-10 min-h-screen flex flex-col items-center justify-center py-20 px-4"
    >
      <!-- Profile Section -->
      <div class="w-full max-w-4xl">
        <div class="relative overflow-hidden rounded-3xl bg-white/85 backdrop-blur-xl border border-pink-200/70 shadow-lg shadow-pink-100/60 px-6 py-8 md:px-10 md:py-10">
          <div class="absolute inset-0 pointer-events-none z-0">
            <div class="absolute inset-0 border border-white/60 rounded-3xl"></div>
            <div class="absolute -top-px left-8 w-24 h-px bg-gradient-to-r from-pink-400/70 to-transparent"></div>
            <div class="absolute bottom-6 -right-px h-24 w-px bg-gradient-to-b from-amber-400/70 to-transparent"></div>
          </div>
          <div class="relative z-10 flex flex-col md:flex-row items-center gap-6 md:gap-10">
            <div class="relative group">
              <div class="absolute -inset-1 bg-gradient-to-r from-pink-500 to-yellow-500 rounded-full blur opacity-30 group-hover:opacity-50 transition duration-300"></div>
              <img
                src="/assets/images/profile.jpg"
                alt="Profile Picture"
                class="relative w-36 h-36 md:w-44 md:h-44 rounded-full object-cover ring-4 ring-white/70 flex-shrink-0 transform transition duration-300 group-hover:scale-105"
              />
            </div>
            <div class="text-center md:text-left space-y-5 flex-1">
              <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/85 backdrop-blur border border-pink-200/70 shadow-sm shadow-pink-100/70 -ml-5">
                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gradient-to-br from-pink-500 to-amber-400 text-white text-[10px] shadow-sm">
                  CH
                </span>
                <span class="hidden md:inline text-[11px] font-medium text-gray-600">Creative Hobbyist / note・apps・art・photo</span>
              </div>
              <div>
                <h1
                  class="text-4xl md:text-5xl font-bold font-['Zen_Maru_Gothic'] bg-gradient-to-r from-gray-800 to-gray-600 bg-clip-text text-transparent tracking-[0.18em]"
                >
                  ぐみ
                </h1>
              </div>
              <div class="space-y-1">
                <p class="font-['Zen_Maru_Gothic'] text-gray-600 text-sm leading-relaxed">
                  note・apps・art・photo をゆるやかに行き来しています。
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Links Section -->
      <div class="mt-10 md:mt-12 w-full max-w-2xl animate-fade-in" style="animation-delay: 0.2s">
        <div class="space-y-8">
          {linkGroups.map((group) => (
            <section class="space-y-3">
              <h2 class="text-xl font-bold mb-6 md:mb-8 text-center text-gray-700 relative tracking-wider">
                <span class="relative z-10">{group.title}</span>
                <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 w-16 h-0.5 bg-gradient-to-r from-pink-500 to-yellow-500"></div>
              </h2>
              <p class="font-['Zen_Maru_Gothic'] text-xs text-gray-500 text-center -mt-4">{group.description}</p>
              <div class="space-y-3">
                {group.links.map((link) => (
                  <a
                    href={link.href}
                    class="group flex items-center justify-between bg-white/80 backdrop-blur-md border border-white/70 px-5 py-4 rounded-2xl shadow-lg shadow-pink-100/60 hover:-translate-y-0.5 hover:shadow-xl transition-all duration-300"
                  >
                    <div class="flex items-center gap-3">
                      {link.icon === 'note' && <img src="/assets/images/note-icon.svg" alt="" class="h-8 w-8" />}
                      {link.icon === 'x' && <i class="fa-brands fa-x-twitter text-2xl text-gray-800"></i>}
                      {link.icon === 'instagram' && <i class="fa-brands fa-instagram text-2xl text-gray-800"></i>}
                      {link.icon === 'github' && <i class="fa-brands fa-github text-2xl text-gray-800"></i>}
                      {link.icon === 'zenn' && <img src="/assets/images/zenn-logo.svg" alt="" class="h-7 w-7" />}
                      {link.icon === 'qiita' && <img src="/assets/images/qiita-icon.png" alt="" class="h-7 w-7 rounded" />}
                      <div class="text-left">
                        <p class="font-['Zen_Maru_Gothic'] text-sm text-gray-600">{link.description}</p>
                        <p class="text-base font-semibold text-gray-800">{link.label}</p>
                      </div>
                    </div>
                    <i class="fa-solid fa-arrow-up-right-from-square text-gray-500 group-hover:text-gray-700 transition-colors duration-300"></i>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>

      <!-- Contact Section -->
      <div class="animate-fade-in w-full max-w-2xl mt-12 md:mt-14" style="animation-delay: 0.4s">
        <h2 class="text-xl font-bold mb-6 md:mb-8 text-center text-gray-700 relative tracking-wider">
          <span class="relative z-10">Contact</span>
          <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 w-16 h-0.5 bg-gradient-to-r from-pink-500 to-yellow-500"></div>
        </h2>
        <div class="space-y-4">
          <a
            href="https://meggumi.com/#contact"
            class="group flex items-center justify-between bg-gradient-to-r from-pink-500 to-yellow-500 text-white px-5 py-4 rounded-2xl shadow-sm hover:scale-[1.02] hover:shadow-lg transition-all duration-300"
          >
            <div class="flex items-center gap-3">
              <i class="fa-solid fa-envelope text-2xl"></i>
              <div class="text-left">
                <p class="font-['Zen_Maru_Gothic'] text-sm opacity-90">相談・連絡はこちら</p>
                <p class="text-base font-semibold">Contact Form</p>
              </div>
            </div>
            <i class="fa-solid fa-arrow-right text-xl"></i>
          </a>
        </div>
      </div>

      <!-- Footer Section -->
      <footer
        class="mt-12 md:mt-16 text-center animate-fade-in"
        style="animation-delay: 0.5s"
      >
        <div class="mb-6 max-w-2xl mx-auto">
          <p class="font-['Zen_Maru_Gothic'] text-gray-700 mb-2">読んでくれてありがとう</p>
          <p class="font-['Zen_Maru_Gothic'] text-sm text-gray-600">お気軽にお声がけください！</p>
        </div>
        <p class="font-['Zen_Maru_Gothic'] text-gray-500 text-xs">&copy; 2025 ぐみ</p>
      </footer>
    </div>
  </body>
</html>
